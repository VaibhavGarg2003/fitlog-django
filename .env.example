# fitlog-django — environment variables
# Copy to .env for local dev. NEVER commit .env.
#
# Same two-environment rule as the Next.js repo:
#   local .env      → the DEV Supabase project
#   Render env vars → PROD

# Django
DJANGO_SECRET_KEY=generate-with--python -c "import secrets; print(secrets.token_urlsafe(50))"
# prod only: DJANGO_ALLOWED_HOSTS=fitlog-django.onrender.com

# Shared Supabase Postgres (Django-owned tables live here too).
# Use the DIRECT connection (5432) — Django is a long-running server with
# CONN_MAX_AGE; it doesn't need the transaction pooler.
# Append ?sslmode=require for Supabase.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require

# Supabase project URL — used to derive the JWKS URL for JWT verification
SUPABASE_URL=https://your-project.supabase.co
